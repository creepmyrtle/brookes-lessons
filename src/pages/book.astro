---
import Base from '../layouts/Base.astro';
import RegistrationForm from '../components/RegistrationForm.astro';
import { pageSEO } from '../data/siteConfig';
---

<Base title={pageSEO.book.title} description={pageSEO.book.description}>
  <div class="contact-page">
    <span class="section-label">Let's Connect</span>
    <h1>Claim Your Free Lesson</h1>
    <p>Enter your name and email below to book your free first lesson. I'll reach out within 24 hours to get you started!</p>
    <RegistrationForm variant="contact" />
  </div>
</Base>
